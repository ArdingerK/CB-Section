async function fetchAsObjectURL(url) {
  const resp = await fetch(url, { cache: 'no-store' });
  if (!resp.ok) throw new Error('Fetch failed: ' + resp.status);
  const blob = await resp.blob();
  return URL.createObjectURL(blob);
}

function svgToDataURL(svgEl, color) {
  const clone = svgEl.cloneNode(true);
  clone.querySelectorAll('*').forEach((n) => {
    if (n.tagName && n.tagName.toLowerCase() !== 'svg') {
      n.setAttribute('fill', color);
      n.setAttribute('stroke', color);
      n.removeAttribute('style');
    }
  });
  clone.setAttribute('xmlns', 'http://www.w3.org/2000/svg');
  const svgText = new XMLSerializer().serializeToString(clone);
  return 'data:image/svg+xml;charset=utf-8,' + encodeURIComponent(svgText);
}
function positionHintOverBoard() {
  const hint = root.querySelector('.pc-sd__hint');
  const canvas = root.querySelector('.pc-sd__canvas');
  if (!hint || !canvas) return;
  updateHintVisibility();
if (hint.style.display === 'none') return;

  // If something is already on the board, never show the hint again
  if (root.querySelector('.pc-sd__placed')) {
    hint.style.display = 'none';
    return;
  }

  const wrap = canvas.closest('.pc-sd__canvas-wrap');
  if (!wrap) return;

  hint.style.display = '';

  const canvasRect = canvas.getBoundingClientRect();
  const wrapRect = wrap.getBoundingClientRect();

  const cx = (canvasRect.left - wrapRect.left) + (canvasRect.width / 2);
  const cy = (canvasRect.top - wrapRect.top) + (canvasRect.height / 2);

  hint.style.position = 'absolute';
  hint.style.left = cx + 'px';
  hint.style.top = cy + 'px';
  hint.style.transform = 'translate(-50%, -50%)';
  hint.style.zIndex = '50';
  hint.style.pointerEvents = 'none';
}

function loadImage(src) {
  return new Promise((resolve, reject) => {
    const img = new Image();
    img.crossOrigin = 'anonymous';
    img.onload = () => resolve(img);
    img.onerror = reject;
    img.src = src;
  });
}
