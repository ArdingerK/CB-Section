    async function createPlacedStencil(item, x, y, packKey) {
    const hint = root.querySelector('.pc-sd__hint');
if (hint) {
  hint.style.display = 'none';
  updateHintVisibility(); 
}


    const el = document.createElement('div');
    el.className = 'pc-sd__placed';
    el.dataset.w = item.w;
    el.dataset.h = item.h;
   el.dataset.rot = "0";
   el.dataset.src = item.src;
   el.dataset.pack = (packKey || slugifyPackKey(item.pack) || '');


    el.style.left = x + '%';
    el.style.top = y + '%';
    el.style.setProperty('--stencil-color', currentColor);
    

    try {
      const res = await fetch(item.src, { cache: 'no-store' });
      if (!res.ok) throw new Error('Stencil fetch failed');
      const rawText = await res.text();

      if (rawText.includes('<svg')) {
        const parser = new DOMParser();
        const svgDoc = parser.parseFromString(rawText, 'image/svg+xml');
        const svgEl = svgDoc.querySelector('svg');
        if (svgEl) {
  // Remove any embedded CSS inside the SVG that can override your colors
  svgEl.querySelectorAll('style').forEach(s => s.remove());

  // Remove inline styling + hard-coded fills/strokes
  svgEl.querySelectorAll('*').forEach(n => {
    n.removeAttribute('style');
    n.removeAttribute('fill');
    n.removeAttribute('stroke');
  });

  el.appendChild(svgEl);
} else {

          el.innerHTML = `<img src="${item.src}" style="filter: drop-shadow(0 0 0 ${currentColor})">`;
        }
      } else {
        el.innerHTML = `<img src="${item.src}" style="filter: drop-shadow(0 0 0 ${currentColor})">`;
      }
    } catch(e) {
      el.innerHTML = `<img src="${item.src}">`;
    }

    applyScale(el);
    stage.appendChild(el);
    updateHintVisibility();
    clearSelection();
    el.classList.add('selected');
    selectedEls.add(el);
    el.onpointerdown = (e) => {
  // stop page scroll while dragging on mobile
  e.preventDefault();
  try { el.setPointerCapture(e.pointerId); } catch(_) {}

  // selection logic
  if (e.shiftKey) {
    if (selectedEls.has(el)) {
      el.classList.remove('selected');
      selectedEls.delete(el);
    } else {
      el.classList.add('selected');
      selectedEls.add(el);
    }
  } else {
    if (!(selectedEls.has(el) && selectedEls.size > 1)) {
      clearSelection();
      el.classList.add('selected');
      selectedEls.add(el);
    }
  }

  if (selectedEls.size === 0) return;

  const startX = e.clientX, startY = e.clientY;
  const stageEl =
  root.querySelector('.pc-sd__stage') ||
  root.querySelector('.pc-sd__stage-inner') ||
  root.querySelector('[data-pc-sd-stage]') ||
  root.querySelector('.pc-sd__canvas-wrap') ||
  root;

const rect = stageEl.getBoundingClientRect();


  const starts = Array.from(selectedEls).map(s => ({
    el: s,
    lx: parseFloat(s.style.left),
    ly: parseFloat(s.style.top)
  }));

  const pMove = (pm) => {
    pm.preventDefault();
    const dxPct = ((pm.clientX - startX) / rect.width) * 100;
    const dyPct = ((pm.clientY - startY) / rect.height) * 100;

    starts.forEach(o => {
      o.el.style.left = (o.lx + dxPct) + '%';
      o.el.style.top  = (o.ly + dyPct) + '%';
    });
  };

    const pUp = () => {
    try { el.releasePointerCapture(e.pointerId); } catch(_) {}
    window.removeEventListener('pointermove', pMove);
    window.removeEventListener('pointerup', pUp);
    window.removeEventListener('pointercancel', pUp);
  };

  window.addEventListener('pointermove', pMove, { passive: false });
  window.addEventListener('pointerup', pUp);
  window.addEventListener('pointercancel', pUp);

  e.stopPropagation();
};
}    

  function applyScale(el) {
    const boardVal = root.querySelector('.pc-sd__board-select')?.value || 'porch';
    const cfg = boardConfigs[boardVal] || boardConfigs.porch;

    const flipped = canvas.dataset.flipped === 'true';
    const defaultIsH = (cfg.defaultOrientation || 'vertical') === 'horizontal';
    const isH = flipped ? !defaultIsH : defaultIsH;
    const bW = isH ? Math.max(cfg.wIn, cfg.hIn) : Math.min(cfg.wIn, cfg.hIn);
    const bH = isH ? Math.min(cfg.wIn, cfg.hIn) : Math.max(cfg.wIn, cfg.hIn);

    const sW = parseFloat(el.dataset.w) * 0.9;
    el.style.setProperty('--calc-width', (sW / bW * 100) + '%');

    const sH = parseFloat(el.dataset.h);
    if (sH > 0) {
      el.style.setProperty('--calc-height', (sH * 0.9 / bH * 100) + '%');
    } else {
      el.style.setProperty('--calc-height', 'auto');
    }
  }

  function clearBoard() {
    stage.querySelectorAll('.pc-sd__placed').forEach(el => el.remove());
    selectedEls.clear();
    const hint = root.querySelector('.pc-sd__hint');
    if (hint) hint.style.display = 'block';
  }

function updateBoard() {
  console.log("updateBoard called");

  const val = root.querySelector('.pc-sd__board-select').value;
  const cfg = boardConfigs[val];
  if (!cfg) return;

  const flipped = canvas.dataset.flipped === 'true';
  const defaultIsH = (cfg.defaultOrientation || 'vertical') === 'horizontal';
  const isH = flipped ? !defaultIsH : defaultIsH;
  canvas.dataset.orientation = isH ? 'horizontal' : 'vertical';

  const base = Number(cfg.dW);
  const wIn  = Number(cfg.wIn);
  const hIn  = Number(cfg.hIn);

  if (!base || !wIn || !hIn) return;

  const isWreath = val === 'wreath';
  let w;
  let h;

  if (isWreath) {
    // Wreath keeps its natural 15x5 ratio; flipping only swaps width/height.
    const naturalW = base;
    const naturalH = base * (hIn / wIn);
    const naturalIsH = wIn >= hIn;
    const shouldSwap = isH !== naturalIsH;
    w = shouldSwap ? naturalH : naturalW;
    h = shouldSwap ? naturalW : naturalH;
  } else {
    // Calculate board in its natural orientation from width/height ratio.
    const naturalW = base;
    const naturalH = base * (hIn / wIn);
    const naturalIsH = wIn >= hIn;

    // Flip by swapping dimensions only when target orientation differs from natural.
    const shouldSwap = isH !== naturalIsH;
    w = shouldSwap ? naturalH : naturalW;
    h = shouldSwap ? naturalW : naturalH;
  }

  // Set canvas size ONLY
  const canvasEl = root.querySelector('.pc-sd__canvas');
  if (canvasEl) {
    canvasEl.style.setProperty('--boardWpx', `${w}px`);
    canvasEl.style.setProperty('--boardHpx', `${h}px`);
    canvasEl.classList.toggle('is-flipped', flipped && !isWreath);
    canvasEl.classList.toggle('is-wreath-rotated', flipped && isWreath);
  }

  // Background image
  if (boardImg) {
    const bg = (cfg.bg ? String(cfg.bg) : '').trim();

    if (!bg) {
      boardImg.style.display = 'none';
      canvas.style.backgroundColor = '#1a1a1a';
    } else {
      boardImg.style.display = 'block';
      boardImg.style.opacity = '1';
      boardImg.src = bg;
    }
  }

  // Fit board ONLY once on initial load
  if (!userSetZoom && !root.__pc_sd_has_fitted_once) {
    root.__pc_sd_has_fitted_once = true;
    fitBoardToViewport();
  }

  // Bind resize/orientation once
  if (!root.__pc_sd_fit_bound) {
    root.__pc_sd_fit_bound = true;
    window.addEventListener('resize', () => fitBoardToViewport(), { passive: true });
    window.addEventListener('orientationchange', () => fitBoardToViewport(), { passive: true });
  }

  // Re-apply layout logic
  setTimeout(() => {
    stage.querySelectorAll('.pc-sd__placed').forEach(applyScale);
    updateHintVisibility();
    buildPackListsFromLib(LIB);
    refreshPackSelectOptions();
    updateStencilFiltering();
  }, 50);
}

