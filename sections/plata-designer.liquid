<!-- =======================
     STENCIL DESIGNER (SECTION WRAPPER)
======================= -->
<div class="pc-sd"
  id="pc-sd-{{ section.id }}"
  data-section-id="{{ section.id }}"
  data-bg-porch="{{ section.settings.board_porch_image | image_url: width: 2000 }}"
  data-bg-oval="{{ section.settings.board_oval_image | image_url: width: 2000 }}"
  data-bg-wreath="{{ section.settings.board_wreath_image | image_url: width: 2000 }}"
  data-bg-framed="{{ section.settings.board_framed_pine_image | image_url: width: 2000 }}"
  data-bg-framed-pine="{{ section.settings.board_framed_pine_image | image_url: width: 2000 }}"
  data-bg-framed-white="{{ section.settings.board_framed_white_image | image_url: width: 2000 }}"
>

<!-- =======================
     STEP 1 (TOP CARD)
======================== -->
<div class="pc-sd__topsteps">

  <!-- STEP 1 as a drawer (mobile toggle) -->
  <div class="pc-sd__drawer pc-sd__drawer--step1" data-drawer="board" data-open="false">

    <button
      type="button"
      class="pc-sd__drawer-toggle pc-sd__drawer-toggle--1"
      aria-expanded="true"
    >
      <span class="pc-sd__drawer-num pc-sd__drawer-num--1">1</span>
      <span class="pc-sd__drawer-title">Choose your chalkboard</span>
      <span class="pc-sd__drawer-sub">Tap to hide/show</span>
      <span class="pc-sd__drawer-icon" aria-hidden="true">▾</span>
    </button>

    <div class="pc-sd__drawer-panel">

      <div class="pc-sd__stepcard pc-sd__stepcard--1">

        <div class="pc-sd__stephead pc-sd__stephead--sr">
          <span class="pc-sd__stepnum">1</span>
          <div>
            <div class="pc-sd__steptitle">Choose your chalkboard</div>
            <div class="pc-sd__stepsub">Choose your chalkboard size and orientation to get started</div>
          </div>
        </div>

        <!-- LEFT COLUMN: help text + dropdown -->
        <div class="pc-sd__input-row pc-sd__row">
          <div class="pc-sd__board-help">
          </div>
          <select
            id="board-{{ section.id }}"
            class="pc-sd__select pc-sd__board-select"
          >
            <option value="porch">Porch Board (58&quot; x 7.5&quot;)</option>
            <option value="oval">Oval Board (11&quot; x 14&quot;)</option>
            <option value="wreath">Wreath Board (15&quot; x 5&quot;)</option>
            <option value="framed">Framed Board (12&quot; x 17&quot;)</option>
          </select>
        </div>

        <!-- RIGHT COLUMN: Flip Board + Zoom stacked and centered -->
        <div class="pc-sd__step1-controls">
          <button
            type="button"
            class="pc-sd__btn pc-sd__btn--ghost"
            data-orientation-toggle
          >
            Flip Board
          </button>

          <div class="pc-sd__zoomline">
            <div class="pc-sd__zoomlabel">Zoom</div>
            <div class="pc-sd__zoomctrl">
              <input
                type="range"
                id="zoom-slider-{{ section.id }}"
                min="0.3"
                max="2.5"
                step="0.1"
                value="1"
                class="pc-sd__range"
              >
              <span id="zoom-value-{{ section.id }}" class="pc-sd__zoomvalue">100%</span>
            </div>
          </div>
        </div>

      </div><!-- /.pc-sd__stepcard--1 -->

    </div><!-- /.pc-sd__drawer-panel -->

  </div><!-- /.pc-sd__drawer--step1 -->

</div><!-- /.pc-sd__topsteps -->
<!-- =======================
     MAIN LAYOUT (DESKTOP: 2 cols)
     LEFT: Sidebar (Step 2 + Step 3)
     RIGHT: Canvas
======================== -->
<div class="pc-sd__layout pc-sd__mobile-rail">

  <!-- =======================
       SIDEBAR (STEP 2 + STEP 3)
  ======================== -->
  <div class="pc-sd__sidebar">

    <!-- =======================
         STEP 2 / Stencils (DRAWER)
    ======================== -->
    <div class="pc-sd__drawer" data-drawer="stencils" data-open="false">
      <button
        type="button"
        class="pc-sd__drawer-toggle pc-sd__drawer-toggle--2"
        aria-expanded="false"
      >
        <span class="pc-sd__drawer-num pc-sd__drawer-num--2">2</span>
        <span class="pc-sd__drawer-title">Stencils</span>
        <span class="pc-sd__drawer-sub">Tap to hide/show letters</span>
        <span class="pc-sd__drawer-icon" aria-hidden="true">▾</span>
      </button>

      <div class="pc-sd__drawer-panel">
        <div class="pc-sd__stepcard pc-sd__stepcard--2">
          <div class="pc-sd__stephead">
            <span class="pc-sd__stepnum">2</span>
            <div>
              <div class="pc-sd__steptitle">Choose your stencils</div>
              <div class="pc-sd__stepsub">
                Craft your message with letter stencils, then decorate your sign with design stencils from our optional stencil sets<br><strong>Tap the stencil to select, then tap or drag the board to place</strong>
              </div>
            </div>
          </div>

          <div class="pc-sd__sidebar-section pc-sd__design">

            <select class="pc-sd__select pc-sd__pack-select" data-jump="designpacks">
              <option value="__all__">Loading Packs...</option>
            </select>

           <div class="pc-sd__helperline"></div>

<!-- OPTIONAL PACKS (moved up under Included) -->
<div class="pc-sd__optional-controls" style="margin-top:12px;">

  <select class="pc-sd__select pc-sd__optional-pack-add">
    <option value="">Select a pack…</option>
  </select>

  <!-- Selected pack chips -->
  <div class="pc-sd__chip-row" style="margin-top:10px;"></div>

  <!-- Clear button -->
  <div class="pc-sd__optional-actions">
  <button type="button" class="pc-sd__btn pc-sd__btn--ghost pc-sd__optional-clear">Clear optional packs </button>
  <button type="button" class="pc-sd__back-to-included">Back to kit letters 🔤</button>
</div>

</div>

<!-- Banner -->
<div class="pc-sd__autobanner pc-sd__autobanner--sidebar">
  Your chalkboard kit stencils are ready below 👇
</div>

<!-- LETTERS (Always visible) -->
<div class="pc-sd__palette">
  <div class="pc-sd__grid" id="stencil-grid-{{ section.id }}" data-jump="designgrid">
    <div class="pc-sd__loading">Syncing Library...</div>
  </div>
</div>


          </div><!-- /.pc-sd__design -->
        </div><!-- /.pc-sd__stepcard--2 -->
      </div><!-- /.pc-sd__drawer-panel -->
    </div><!-- /.pc-sd__drawer (stencils) -->


    <!-- =======================
         STEP 3 / Tools & Colors (DRAWER)
    ======================== -->
    <div class="pc-sd__drawer" data-drawer="tools" data-open="false">
      <button
        type="button"
        class="pc-sd__drawer-toggle"
        aria-expanded="false"
      >
        <span class="pc-sd__drawer-num pc-sd__drawer-num--3">3</span>
        <span class="pc-sd__drawer-title">Tools & Colors</span>
        <span class="pc-sd__drawer-sub">Tap to hide/show</span>
        <span class="pc-sd__drawer-icon" aria-hidden="true">▾</span>
      </button>

      <div class="pc-sd__drawer-panel">
        <div class="pc-sd__stepcard pc-sd__stepcard--3">
          <div class="pc-sd__mobile-substep">
           Tap a stencil to add it • Use Multi-Select to move together
          </div>

          <div class="pc-sd__stephead">
            <span class="pc-sd__stepnum">3</span>
            <div>
              <div class="pc-sd__steptitle">Get creative</div>
              <div class="pc-sd__stepsub"></div>
            </div>
          </div>

          <div class="pc-sd__sidebar-bottom pc-sd__step3-grid">

            <div class="pc-sd__step3-head">
              <div class="pc-sd__step-label" data-step="3">Get Creative</div>
              <div class="pc-sd__step3-sub">
                Tap to highlight stencil on the board, then tap color, outline, rotate to change the appearance.<br> Hold shift to select multiple stencils to use the align function.
              </div>
            </div>

            <div class="pc-sd__tools-colors">

              <!-- TOOLS COLUMN -->
              <div class="pc-sd__tools pc-sd__step3-col pc-sd__step3-tools">
                <div class="pc-sd__sidebar-section pc-sd__sidebar-section--border">
                  <div class="pc-sd__column-title"><strong>Tools</strong></div>

                  <div class="pc-sd__align-block" style="margin: 10px 0 8px;">
                    <div class="pc-sd__minihead">Align Selection</div>
                    <div class="pc-sd__btn-strip">
                      <button type="button" class="pc-sd__tool-btn" data-align="align-vertical" title="Align Vertically (same X)">│</button>
                      <button type="button" class="pc-sd__tool-btn" data-align="align-bottom" title="Align Bottom">⎵</button>
                      <button type="button"
                      class="pc-sd__tool-btn"
                      data-align="space"
  title="Auto Space">
  Auto Space
</button>
                    </div>
                  </div>

                  <div class="pc-sd__button-bar">
                    <button type="button" class="pc-sd__btn pc-sd__btn--small pc-sd__btn--ghost pc-sd__btn--full" data-rotate-left>Rotate ⟲</button>
                    <button type="button" class="pc-sd__btn pc-sd__btn--small pc-sd__btn--ghost pc-sd__btn--full" data-rotate-right>Rotate ⟳</button>
                  </div>

                  <button type="button" class="pc-sd__btn pc-sd__btn--small pc-sd__btn--danger pc-sd__btn--full" data-delete-selected>
                    Remove Selected
                  </button>

                  <button type="button" class="pc-sd__btn pc-sd__btn--ghost pc-sd__btn--full" data-clear-board style="margin-top:12px;">
                    Erase Board
                  </button>
                </div>
              </div>

              <!-- COLORS COLUMN -->
              <div class="pc-sd__colors pc-sd__step3-col pc-sd__step3-colors">
                <div class="pc-sd__column-title"><strong>Colors</strong></div>

                <div class="pc-sd__sidebar-section pc-sd__sidebar-section--border">

                  <!-- FILL COLORS -->
                  <div class="pc-sd__color-group">
                    <div class="pc-sd__minihead" style="opacity:.8;">Standard Colors</div>
                    <div class="pc-sd__swatches" id="swatches-6-{{ section.id }}"></div>
                  </div>

                  <div class="pc-sd__color-group" style="margin-top: 12px;">
                    <div class="pc-sd__minihead">12-Pack</div>
                    <div class="pc-sd__swatches" id="swatches-12-{{ section.id }}"></div>
                  </div>

                  <div class="pc-sd__current-indicator" style="margin-top: 12px; font-size: 13px; font-weight: bold;">
                    Color: <span id="color-name-display-{{ section.id }}">White</span>
                  </div>

                  <!-- OUTLINE CONTROLS -->
                  <div class="pc-sd__outline" style="margin-top: 16px; padding-top: 12px; border-top: 1px dashed rgba(0,0,0,.15);">
                    <label class="pc-sd__outline-toggle" style="display:flex;align-items:center;gap:10px;font-weight:800;cursor:pointer;">
                      <input type="checkbox" id="outline-on-{{ section.id }}">
                      <span>Outline</span>
                    </label>

                    <div id="outline-controls-{{ section.id }}" style="margin-top:10px; display:none;">
                      <div class="pc-sd__minihead" style="opacity:.8;">Outline color</div>
                      <div class="pc-sd__swatches" id="swatches-outline-{{ section.id }}"></div>

                      <div style="margin-top:10px;">
                        <div class="pc-sd__minihead" style="opacity:.8;">Outline thickness</div>
                        <input
                        type="range"
                        id="outline-width-{{ section.id }}"
                        min="1"
                        max="20"
                        step="1"
                        value="3"
                        style="width:100%;"
                        >
                        
                      </div>
                    </div>
                  </div>
                  <!-- /OUTLINE CONTROLS -->

                </div><!-- /.pc-sd__sidebar-section -->
              </div><!-- /.pc-sd__colors -->

            </div><!-- /.pc-sd__tools-colors -->
          </div><!-- /.pc-sd__sidebar-bottom -->
        </div><!-- /.pc-sd__stepcard--3 -->
      </div><!-- /.pc-sd__drawer-panel -->
    </div><!-- /.pc-sd__drawer (tools) -->

  </div><!-- /.pc-sd__sidebar -->

  <!-- RIGHT: Canvas goes here (not included in your snippet) -->

    <!-- =======================
         MOBILE ZOOM BAR (between stencils and canvas)
         (Hidden on desktop via CSS)
    ======================== -->
    <div class="pc-sd__zoomline pc-sd__zoomline--between">
      <div class="pc-sd__zoomlabel">Zoom</div>
      <div class="pc-sd__zoomctrl">
        <input
          type="range"
          id="zoom-slider-mobile-{{ section.id }}"
          min="0.3"
          max="2.5"
          step="0.1"
          value="1"
          class="pc-sd__range"
        >
        <span id="zoom-value-mobile-{{ section.id }}" class="pc-sd__zoomvalue">100%</span>
      </div>
    </div>

  <!-- RIGHT COLUMN (Canvas + Step 4 share the same centering system) -->
  <div class="pc-sd__rightcol">


  <!-- CANVAS -->
  <div class="pc-sd__canvas-container">
    <div class="pc-sd__canvas-scroll-area">

      <!-- Board + Quicktools need a common positioned anchor -->
      <div class="pc-sd__canvas-wrapper">
        <div class="pc-sd__canvas-wrap">

          <!-- Quicktools anchored to the board wrapper (NOT the scroll area edge) -->
          <div class="pc-sd__quicktools" aria-label="Quick tools">
            <button type="button" class="pc-sd__qt" data-qt="letters">🔤</button>
            <button type="button" class="pc-sd__qt" data-qt="design">🌸</button>
            <button type="button" class="pc-sd__qt" data-qt="colors">🎨</button>
            <button type="button" class="pc-sd__qt" data-qt="rotateL">⟲</button>
            <button type="button" class="pc-sd__qt" data-qt="rotateR">⟳</button>
            <button type="button" class="pc-sd__qt" data-qt="delete">🗑</button>
          </div>

          <!-- Hint sits OUTSIDE the clipped board -->
          <div class="pc-sd__hint">Click a stencil, then click the board</div>

          <!-- Board canvas stays clipped -->
          <div class="pc-sd__canvas" id="canvas-{{ section.id }}" data-board="porch" data-orientation="vertical">
            <img class="pc-sd__board-img-el" alt="Board Background" draggable="false" />
            <div class="pc-sd__stage"></div>
          </div>

        </div><!-- /.pc-sd__canvas-wrap -->
      </div><!-- /.pc-sd__canvas-wrapper -->

    </div><!-- /.pc-sd__canvas-scroll-area -->
  </div><!-- /.pc-sd__canvas-container -->
  <!-- STEP 4 -->
<div class="pc-sd__bottombar" role="region" aria-label="Save or add to cart">
  <div class="pc-sd__bottombar-text">
    <div class="pc-sd__step4head">
      <span class="pc-sd__stepnum pc-sd__stepnum--inline">4</span>
      <span class="pc-sd__love pc-sd__love--hand">Love how it turned out?</span>
    </div>

    <div class="pc-sd__step4sub">
      Save <strong>20%</strong> on stencil packs
      <span class="pc-sd__dot">•</span> buy <strong>2+</strong> packs
      <span class="pc-sd__dot">•</span> or bundle with a chalkboard
    </div>
  </div>

  <div class="pc-sd__bottombar-actions">
    <button type="button" class="pc-sd__btn pc-sd__btn--ghost" data-export-image>
      Save as PNG
    </button>
    <button type="button" class="pc-sd__btn pc-sd__btn--primary" data-add-to-cart-design>
      Add Design to Cart
    </button>
  </div>
</div>

</div><!-- /.pc-sd__rightcol -->

</div><!-- /.pc-sd__layout -->


  <!-- =======================
     MODAL (Add chalkboard?)
======================== -->
<div class="pc-sd__modal" data-pc-sd-modal aria-hidden="true" hidden>
  <div class="pc-sd__modal-backdrop" aria-hidden="true"></div>

  <div class="pc-sd__modal-card" role="dialog" aria-modal="true" aria-labelledby="pc-sd__modal-title" aria-describedby="pc-sd__modal-desc">

    <div class="pc-sd__modal-title" id="pc-sd__modal-title">Complete your kit?</div>

    <div class="pc-sd__modal-preview">
      <img class="pc-sd__modal-img" alt="" />
    </div>
   

   <div class="pc-sd__modal-sub">
  You're designing on the <strong>58" Porch Chalkboard</strong>. Add the kit so you can make this sign at home.
</div>

    <div class="pc-sd__modal-bullets">
      <div><span class="pc-sd__bullet">•</span> Outdoor &amp; weather-safe</div>
      <div><span class="pc-sd__bullet">•</span> Magnetic</div>
      <div><span class="pc-sd__bullet">•</span> Reusable for every season</div>
    </div>
     <div class="pc-sd__minihead">
  Chalkboard Kit Includes:
</div>

    <!-- shows only when eligible -->
    <div class="pc-sd__modal-savings" hidden>
      <span class="pc-sd__savings-pill">Bundle &amp; Save</span>
      Save <strong>20%</strong> on stencil packs when you add a board
    </div>

    <!-- Only shown when boardKey === "framed" -->
    <div class="pc-sd__modal-frame" hidden>
  <div><strong>Choose frame</strong></div>

  <label>
    <input type="radio" name="pc_sd_frame" value="pine" checked>
    <span>Pine</span>
  </label>

  <label>
    <input type="radio" name="pc_sd_frame" value="white">
    <span>White</span>
  </label>
</div>

    <div class="pc-sd__modal-includes-wrap"></div>

    <div class="pc-sd__modal-actions">
      <button type="button" class="pc-sd__btn pc-sd__btn--ghost pc-sd__modal-no" data-modal-no>
  I already have the board
</button>
<button type="button" class="pc-sd__btn pc-sd__btn--primary pc-sd__modal-yes" data-modal-yes>
  Add the kit
</button>

    </div>

    <div class="pc-sd__modal-note">
      Discount applies automatically at checkout when eligible.
    </div>
  </div>
</div>
<div id="drag-ghost-{{ section.id }}"
     style="
       position: fixed;
       width: 50px;
       height: 50px;
       pointer-events: none;
       z-index: 2147483000;
       display: none;
       background-size: contain;
       background-repeat: no-repeat;
       background-position: center;
     ">
</div>

</div>

<style>
/* =========================================================
   PC STENCIL DESIGNER — CLEAN SPLIT: BASE / DESKTOP / MOBILE
   Replace your entire <style> with this.
   ========================================================= */

/* -----------------------------
   BASE (all devices)
------------------------------ */
:root{
  --zoom: 1;
  --stencil-bg:#dddfe0;

  --pc-teal:#4AB6B8;
  --pc-yellow:#FFC42E;
  --pc-orange:#F6AA25;

  --pc-text:#111827;
  --pc-muted:#6b7280;
  --pc-border:rgba(17,24,39,.12);
  --pc-card:#fff;

  --pc-radius:18px;
  --pc-shadow:0 12px 30px rgba(0,0,0,.08);

  /* Workspace height (desktop uses this, mobile overrides naturally) */
  --pc-canvas-h: 800px;
}

/* wrapper */
.pc-sd{
  font-family: system-ui,-apple-system,Segoe UI,Roboto,Arial,sans-serif;
  max-width:1400px;
  margin:0 auto;
  padding:15px;
  color:var(--pc-text);

  /* your unified background look */
  background:#d6ebee;
  border-radius:22px;
}
.pc-sd *{ box-sizing:border-box; }

/* step card base */
.pc-sd__stepcard{
  background:#fff;
  border-radius:18px;
  padding:22px 24px;
  position:relative;
  z-index:2;
  box-shadow:0 6px 18px rgba(0,0,0,.06);
}
.pc-sd__stepcard::after{
  content:'';
  position:absolute;
  inset:10px;
  border-radius:14px;
  pointer-events:none;
}

/* step header */
.pc-sd__stephead{
  display:flex;
  align-items:flex-start;
  gap:12px;
  margin:0px 0 5px;
}
.pc-sd__stepnum{
  width:46px; height:46px;
  border-radius:50%;
  display:inline-grid;
  place-items:center;
  font-family:'Shadows Into Light', cursive;
  font-size:22px;
  font-weight:700;
}
.pc-sd__steptitle{
  font-family:'Shadows Into Light', cursive;
  font-size:28px;
  font-weight: 700;
  letter-spacing:1px;
  color:#1f2937;
  line-height:1.1;
  margin:0;
}
.pc-sd__stepsub{
  font-size:13px;
  color:var(--pc-muted);
  margin-top:6px;
  line-height:1.25;
  margin-bottom: 3px;
}
/* STEP 2 — ensure optional stencil selector is visible */
.pc-sd__drawer[data-drawer="stencils"] .pc-sd__optional-controls {
  display: block !important;
  margin-top: 12px;
}
.pc-sd__drawer[data-drawer="stencils"] .pc-sd__stencil-mode{
  display: grid !important; /* or flex if you prefer */
  gap: 0;
  margin: 10px 0 8px;
}


/* step themes */
.pc-sd__stepcard--1{ border:3px solid #6BBFC2; }
.pc-sd__stepcard--1::after{ border:3px dashed #6BBFC2; }
.pc-sd__stepcard--1 .pc-sd__stepnum{ background:#6BBFC2; color:#fff; }

.pc-sd__stepcard--2{ border:3px solid #FFC42E; }
.pc-sd__stepcard--2::after{ border:3px dashed rgba(255,196,46,.55); }
.pc-sd__stepcard--2 .pc-sd__stepnum{ background:#FFC42E; color:#1f2937; }

.pc-sd__stepcard--3{ border:3px solid #B72467; }
.pc-sd__stepcard--3::after{ border:3px dashed rgba(183,36,103,.45); }
.pc-sd__stepcard--3 .pc-sd__stepnum{ background:#B72467; color:#fff; }

/* Step 4 */
.pc-sd__bottombar{
  width:100%;
  max-width:860px;
  margin:18px auto 28px;
  padding:18px 24px;
  border:3px solid #85BF44;
  border-radius:18px;
  background:#fff;
  margin-top: 32px; 

  flex: 0 0 auto;
  margin-top: 16px;              /* optional spacing */
  position: sticky;
  bottom: 0;
  z-index: 10;
}
.pc-sd__bottombar::after{
  content:'';
  position:absolute;
  inset:10px;
  border:2px dashed rgba(133,191,68,.55);
  border-radius:14px;
  pointer-events:none;
}
.pc-sd__bottombar-text{ text-align:center; position:relative; z-index:1; }
.pc-sd__step4head{
  display:inline-flex;
  align-items:center;
  gap:10px;
  position:relative;
  z-index:1;
  margin:0 auto;
}
.pc-sd__stepnum--inline{
  width:44px; height:44px;
  border-radius:50%;
  display:inline-grid;
  place-items:center;
  background:#85BF44;
  color:#fff;
  font-family:'Shadows Into Light', cursive;
  font-size:22px;
  font-weight:700;
}
.pc-sd__love--hand{
  font-family:'Shadows Into Light', cursive;
  font-size:30px;
  font-weight:700;
  letter-spacing:1px;
  color:#1f2937;
}
.pc-sd__bottombar-actions{
  display:flex;
  justify-content:center;
  gap:14px;
  margin-top:12px;
  position:relative;
  z-index:1;
}
.pc-sd__bottombar-actions .pc-sd__btn{
  border-radius:999px;
  padding:12px 18px;
  font-weight:800;
  margin-top: 32px; 
}

/* controls */
.pc-sd__select{
  width:100%;
  padding:6px 6px;
  border:2px solid var(--pc-border);
  border-radius:12px;
  background:#fff;
  font-size:14px;
}

.pc-sd__btn{
  border:1px solid rgba(0,0,0,.22);
  background:#fff;
  padding:10px 14px;
  cursor:pointer;
  border-radius:12px;
  font-weight:900;
  font-size:14px;
}
.pc-sd__btn--small{ padding:9px 10px; font-size:13px; }
.pc-sd__btn--full{ width:100%; }
