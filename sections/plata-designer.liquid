// --- MODAL: Ask to add board ---
function askAddBoardModal() {
  return new Promise((resolve) => {
    const modal =
      root.querySelector('[data-pc-sd-modal]') ||
      document.querySelector('[data-pc-sd-modal]');

    console.log('[Stencil Designer] modal found?', !!modal, modal);
    if (!modal) return resolve(false);

    const yesBtn   = modal.querySelector('[data-modal-yes]');
    const noBtn    = modal.querySelector('[data-modal-no]');
    const backdrop = modal.querySelector('.pc-sd__modal-backdrop');

    const sub       = modal.querySelector('.pc-sd__modal-sub');
    const frameWrap = modal.querySelector('.pc-sd__modal-frame'); // optional
    const imgEl     = modal.querySelector('.pc-sd__modal-img');
    const savingsEl = modal.querySelector('.pc-sd__modal-savings');

    const getBoardKeyNow = () =>
  root.querySelector('.pc-sd__board-select')?.value || 'porch';

const includesEl = modal.querySelector('.pc-sd__modal-includes-wrap');

    const close = (val) => {
      modal.classList.remove('is-open');
      modal.setAttribute('aria-hidden', 'true');
      modal.hidden = true;
      cleanup();
      resolve(val);
    };

    const onYes = () => {
      const boardKeyNow = getBoardKeyNow();

      // If framed, return which frame they picked
      if (boardKeyNow === 'framed') {
        const picked =
          modal.querySelector('input[name="pc_sd_frame"]:checked')?.value || 'pine';
        close(picked); // "pine" or "white"
        return;
      }

      // Other boards = simple true
      close(true);
    };

    const onNo = () => close(false);
    const onBackdrop = () => close(false);
    const onEsc = (e) => { if (e.key === 'Escape') close(false); };

    function cleanup() {
      yesBtn && yesBtn.removeEventListener('click', onYes);
      noBtn && noBtn.removeEventListener('click', onNo);
      backdrop && backdrop.removeEventListener('click', onBackdrop);
      window.removeEventListener('keydown', onEsc);

      // remove framed change listeners (safe)
      const radios = modal.querySelectorAll('input[name="pc_sd_frame"]');
      radios.forEach(r => r.onchange = null);
    }

    yesBtn && yesBtn.addEventListener('click', onYes);
    noBtn && noBtn.addEventListener('click', onNo);
    backdrop && backdrop.addEventListener('click', onBackdrop);
    window.addEventListener('keydown', onEsc);

    // ---- Configure modal content ----
    const boardKeyNow = getBoardKeyNow();
    const label = getBoardNiceLabel(boardKeyNow);

    // Subtext
    if (sub) sub.innerHTML = `You're designing on the <strong>${label}</strong>`;

    // Preview image (use current board image if available)
    if (imgEl) {
      const src = (boardImg && boardImg.src) ? boardImg.src : '';
      if (src) {
        imgEl.src = src;
        imgEl.alt = label;
        imgEl.style.display = 'block';
      } else {
        imgEl.style.display = 'none';
      }
    }

    // Savings line: show only if eligible (data set by handleAddDesignToCart)
    if (savingsEl) {
      const showSavings = !!modal.dataset.showSavings; // "1" or ""
      savingsEl.hidden = !showSavings;
    }

    // Frame picker visibility
    if (frameWrap) frameWrap.style.display = (boardKeyNow === 'framed') ? 'block' : 'none';

    // Update YES button label with price when possible
    (async () => {
      const yes = modal.querySelector('[data-modal-yes]');
      if (!yes) return;

      const getVariantForCurrentBoard = () => {
        const currentKey = getBoardKeyNow();

        if (currentKey === 'framed') {
          const picked =
            modal.querySelector('input[name="pc_sd_frame"]:checked')?.value || 'pine';
          const framedKey = slugifyPackKey(`board-framed-${picked}`);
          return VARIANTS_BOARDS ? VARIANTS_BOARDS[framedKey] : null;
        }

        const baseKey = slugifyPackKey(`board-${currentKey}`);
        return VARIANTS_BOARDS ? VARIANTS_BOARDS[baseKey] : null;
      };

      const refreshYes = async () => {
        const currentKey = getBoardKeyNow();
        const currentLabel = getBoardNiceLabel(currentKey);

        const vid = getVariantForCurrentBoard();
        if (!vid) {
          yes.textContent = `Yes — Add My ${currentLabel}Kit`;
          return;
        }

        const cents = await fetchVariantPriceCents(vid);
        if (typeof cents === 'number') {
          yes.textContent = `Yes — Add My ${currentLabel}Kit · ${formatMoneyCents(cents)}`;
        } else {
          yes.textContent = `Yes — Add My ${currentLabel}Kit`;
        }
      };

      await refreshYes();

      // If framed radio changes, refresh price text
      const radios = modal.querySelectorAll('input[name="pc_sd_frame"]');
      radios.forEach(r => r.onchange = refreshYes);
    })();

    // OPEN
if (includesEl) {
  includesEl.innerHTML = getKitIncludesHTML(boardKeyNow);
}

    modal.hidden = false;
    modal.classList.add('is-open');
    modal.setAttribute('aria-hidden', 'false');
  });
}

// --- MAIN: Add design to cart ---
async function handleAddDesignToCart() {
  console.log('✅ handleAddDesignToCart fired');

  // 0) Safety: variants loaded?
  if (!VARIANTS_PACKS || Object.keys(VARIANTS_PACKS).length === 0) {
    alert("Variant IDs didn't load yet. Check the Variants Google Sheet publish link.");
    return;
  }

  // 1) Collect unique pack keys used on the board
  const placedEls = Array.from(stage.querySelectorAll('.pc-sd__placed'));
  const packsUsed = new Set(
    placedEls
      .map(el => (el.dataset.pack || '').toLowerCase().trim())
      .filter(Boolean)
  );

  // 2) Only OPTIONAL packs become cart items
  const boardKey = root.querySelector('.pc-sd__board-select')?.value || 'porch';
  const prefix = (boardConfigs[boardKey]?.associatedPrefix || boardKey).toLowerCase();
  const optionalPacksUsed = Array.from(packsUsed).filter(pk => isOptionalPackKey(pk, prefix));
  window.optionalPacksUsed = optionalPacksUsed;
 window.VARIANTS_PACKS = VARIANTS_PACKS;
 window.VARIANTS_BOARDS = VARIANTS_BOARDS;
  
  console.log('Optional packs used:', optionalPacksUsed);
  console.log('Available variant keys:', Object.keys(VARIANTS_PACKS));
  console.log('[AddToCart] VARIANTS_PACKS keys:', Object.keys(VARIANTS_PACKS || {}).length);
  console.log('[AddToCart] VARIANTS_BOARDS keys:', Object.keys(VARIANTS_BOARDS || {}).length);


  // 3) Map optional pack keys -> variant IDs
// 3) Map optional pack keys -> variant IDs
const missing = [];
const variantIds = [];

optionalPacksUsed.forEach(pk => {
  const normalizedKey = normalizePackKey(slugifyPackKey(pk));
  const vid = VARIANTS_PACKS[normalizedKey];

  console.log('Pack map lookup:', { pk, normalizedKey, vid });

  if (vid) variantIds.push(vid);
  else missing.push(normalizedKey);
});



  // Dedup
  let uniqueVariantIds = Array.from(new Set(variantIds));

  // 4) Ask about adding the board (even if NO optional packs were used)
  let wantBoard = false;

  // IMPORTANT: for framed, your sheet has board-framed-pine/white (NO board-framed),
  // so do NOT gate the modal on boardVariantId for framed.
  if (boardKey === 'framed') {
    const choice = await askAddBoardModal(); // false OR "pine"/"white"

    if (choice) {
      const framedKey = slugifyPackKey(`board-framed-${choice}`); // board-framed-pine / board-framed-white
      const framedId = VARIANTS_BOARDS ? VARIANTS_BOARDS[framedKey] : null;

      if (framedId) {
        uniqueVariantIds.push(framedId);
      } else {
        console.warn('[Stencil Designer] Missing framed board key in VARIANTS_BOARDS:', framedKey, VARIANTS_BOARDS);
      }
    }
  } else {
    const baseBoardKey = slugifyPackKey(`board-${boardKey}`); // board-porch / board-wreath / board-oval
    const boardVariantId = VARIANTS_BOARDS ? VARIANTS_BOARDS[baseBoardKey] : null;

    if (boardVariantId) {
      wantBoard = await askAddBoardModal(); // false OR true
      if (wantBoard) uniqueVariantIds.push(boardVariantId);
    } else {
      console.warn('[Stencil Designer] No board variant found for key:', baseBoardKey, VARIANTS_BOARDS);
    }
  }

  // 5) Warn about missing packs (but still proceed)
  if (missing.length) {
    alert("Some packs were missing in Variants:\n\n" + missing.join("\n"));
  }

  // 6) Avoid adding duplicates already in cart
  let cart = null;
  try {
    cart = await getCart();
  } catch (e) {
    console.warn('[Stencil Designer] Could not read cart.js, will still try to add.', e);
  }

  const alreadyInCart = new Set(
    cart && Array.isArray(cart.items) ? cart.items.map(it => String(it.id)) : []
  );

  const itemsToAdd = uniqueVariantIds
    .filter(id => !alreadyInCart.has(String(id)))
    .map(id => ({ id: Number(id), quantity: 1 }));

  if (itemsToAdd.length === 0) {
    alert("Nothing new to add (items already in cart).");
    if (window.matchMedia('(min-width: 768px)').matches) {
  window.open('/cart', '_blank');
} else {
  window.location.href = '/cart';
}

    return;
  }

  try {
    await addItemsToCart(itemsToAdd);
    console.log('[AddToCart] uniqueVariantIds:', uniqueVariantIds);
    console.log('[AddToCart] itemsToAdd:', itemsToAdd);
    if (window.matchMedia('(min-width: 768px)').matches) {
  window.open('/cart', '_blank');
} else {
  window.location.href = '/cart';
}

  } catch (e) {
    console.error(e);
    alert("Couldn't add to cart:\n\n" + (e && e.message ? e.message : e));
  }
}

async function exportDesignPNG() {
  const stageEl =
  (stage && typeof stage.container === 'function') ? stage.container() :
  (stage && stage.nodeType === 1) ? stage :
  root.querySelector('.pc-sd__stage') ||
  root.querySelector('[data-pc-sd-stage]') ||
  root.querySelector('.pc-sd__canvas-wrap') ||
  root;

  const stageRect = stageEl.getBoundingClientRect();
  const w = Math.max(1, Math.round(stageRect.width));
  const h = Math.max(1, Math.round(stageRect.height));

  const scale = 2;
  const out = document.createElement('canvas');
  out.width = w * scale;
  out.height = h * scale;
  const ctx = out.getContext('2d');
  ctx.setTransform(scale, 0, 0, scale, 0, 0);

  // Background board
  if (boardImg && boardImg.src) {
    try {
      const boardObjURL = await fetchAsObjectURL(boardImg.src);
      const bImg = await loadImage(boardObjURL);
      ctx.drawImage(bImg, 0, 0, w, h);
      URL.revokeObjectURL(boardObjURL);
    } catch (e) {
      ctx.fillStyle = '#1a1a1a';
      ctx.fillRect(0, 0, w, h);
    }
  } else {
    ctx.fillStyle = '#1a1a1a';
    ctx.fillRect(0, 0, w, h);
  }

  // Placed stencils
  const placedEls = Array.from(stageEl.querySelectorAll('.pc-sd__placed'));

  for (const el of placedEls) {
  const cx = (parseFloat(el.style.left) / 100) * w;
    const cy = (parseFloat(el.style.top) / 100) * h;
    const rot = (parseInt(el.dataset.rot || '0', 10) * Math.PI) / 180;
    const pw = el.offsetWidth;
    const ph = el.offsetHeight;

    const color = (el.style.getPropertyValue('--stencil-color') || currentColor).trim() || '#f5f5f5';

    let srcForDraw = null;
    const svg = el.querySelector('svg');
    const img = el.querySelector('img');

    try {
      if (svg) {
        srcForDraw = svgToDataURL(svg, color);
      } else if (img && img.src) {
        const objURL = await fetchAsObjectURL(img.src);
        srcForDraw = objURL;
      }
      if (!srcForDraw) continue;

      const drawImg = await loadImage(srcForDraw);

      ctx.save();
      ctx.translate(cx, cy);
      ctx.rotate(rot);
      ctx.drawImage(drawImg, -pw / 2, -ph / 2, pw, ph);
      ctx.restore();

      if (srcForDraw.startsWith('blob:')) URL.revokeObjectURL(srcForDraw);
    } catch (e) {
      if (srcForDraw && srcForDraw.startsWith('blob:')) {
        try { URL.revokeObjectURL(srcForDraw); } catch(_) {}
      }
    }
  }

  try {
    return out.toDataURL('image/png');
  } catch (e) {
    throw new Error(
      'PNG export blocked by browser due to image hosting (CORS). ' +
      'If any stencil images are hosted somewhere that blocks export, move them to Shopify Files.'
    );
  }
}

async function handleSaveDesign() {
  const box = ensureDockedPreview();
  const imgEl = box.querySelector('.pc-sd__savebox-img');
  const dl = box.querySelector('.pc-sd__savebox-download');
  const note = box.querySelector('.pc-sd__savebox-note');

  box.style.display = 'block';
  note.textContent = 'Generating image…';

  try {
    const pngDataURL = await exportDesignPNG();
    imgEl.src = pngDataURL;

    const boardKey = root.querySelector('.pc-sd__board-select').value;
    const ts = new Date().toISOString().slice(0,19).replace(/[:T]/g,'-');
    const filename = `plata-design-${boardKey}-${ts}.png`;

    dl.href = pngDataURL;
    dl.download = filename;

    note.textContent = 'Preview created- Download to make your design at home';
  } catch (e) {
    console.error('[Stencil Designer] Save PNG failed:', e);
    note.textContent = (e && e.message) ? e.message : 'Could not export PNG.';
  }
}

