function pcSdInnerStrokeSvg(svg, color, innerPx) {
  if (!svg) return;

  // remove previous inner-stroke overlays
  svg.querySelectorAll('[data-pc-sd-innerstroke="1"]').forEach(n => n.remove());

  // defs
  let defs = svg.querySelector('defs');
  if (!defs) {
    defs = document.createElementNS('http://www.w3.org/2000/svg', 'defs');
    svg.insertBefore(defs, svg.firstChild);
  }

  

  const uid = `pcsd_${Math.random().toString(36).slice(2)}_`;

  drawables.forEach((node, i) => {
    // clip path from the original shape
    const cp = document.createElementNS('http://www.w3.org/2000/svg', 'clipPath');
    const clipId = uid + i;
    cp.setAttribute('id', clipId);

    const clipClone = node.cloneNode(true);
    clipClone.removeAttribute('stroke');
    clipClone.removeAttribute('stroke-width');
    cp.appendChild(clipClone);
    defs.appendChild(cp);

    // stroke overlay: width*2 + clip => visible part is inside only
    const s = node.cloneNode(true);
    s.setAttribute('fill', 'none');
    s.setAttribute('stroke', color);
    s.setAttribute('stroke-width', String(innerPx * 2));
    s.setAttribute('stroke-linejoin', 'round');
    s.setAttribute('stroke-linecap', 'round');
    s.setAttribute('clip-path', `url(#${clipId})`);
    s.setAttribute('data-pc-sd-innerstroke', '1');
    s.style.pointerEvents = 'none';

    node.insertAdjacentElement('afterend', s);
  });
}

