function updateStencilFiltering() {
  const boardKey = root.querySelector('.pc-sd__board-select')?.value || 'porch';
  const prefix = (boardConfigs[boardKey]?.associatedPrefix || boardKey).toLowerCase();
  const selectedPack = getSelectedPack();

  // Show/hide optional controls wrapper
  const optionalWrap = root.querySelector('.pc-sd__optional-controls');
  if (optionalWrap) optionalWrap.style.display = (stencilMode === 'optional') ? 'block' : 'none';

  // Optional mode always previews the UNION of staged packs
  // (staged = selectedOptionalPacks)
  let optionalPreviewSet = null;
  if (stencilMode === 'optional') {
    optionalPreviewSet = new Set(Array.from(selectedOptionalPacks));
  }


  root.querySelectorAll('.pc-sd__item').forEach(el => {
    const packKey = (el.dataset.pack || '').toLowerCase();

    const includedForThisBoard = isIncludedForBoard(packKey, prefix);
    const optionalByRules = isOptionalPackKey(packKey, prefix);

    if (stencilMode === 'included') {
      const match = includedForThisBoard && (selectedPack === '__all__' || packKey === selectedPack);
      el.style.display = match ? 'flex' : 'none';
      return;
    }

    // optional mode
    if (!optionalByRules) {
      el.style.display = 'none';
      return;
    }

    // dropdown preview
       // UNION preview (staged packs)
    if (!optionalPreviewSet || optionalPreviewSet.size === 0) {
      el.style.display = 'none';
      return;
    }

    el.style.display = optionalPreviewSet.has(packKey) ? 'flex' : 'none';

  });
}

