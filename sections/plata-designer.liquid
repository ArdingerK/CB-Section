    const pk = el.dataset.pack;
const bg = bgForPack(pk);
if (bg) el.style.setProperty('--pack-bg', bg);


   // Inline SVG for palette so we can normalize visual size
(async () => {
  try {
    const res = await fetch(item.src, { cache: 'force-cache' });
    const txt = await res.text();

    if (!txt.includes('<svg')) throw new Error('Not SVG');

    const doc = new DOMParser().parseFromString(txt, 'image/svg+xml');
    const svg = doc.querySelector('svg');
    if (!svg) throw new Error('Bad SVG');

    // Ensure viewBox exists
    if (!svg.getAttribute('viewBox')) {
      const w = parseFloat(svg.getAttribute('width')) || 100;
      const h = parseFloat(svg.getAttribute('height')) || 100;
      svg.setAttribute('viewBox', `0 0 ${w} ${h}`);
    }

    // Strip styles that break consistency
    svg.querySelectorAll('style').forEach(s => s.remove());
    svg.querySelectorAll('*').forEach(n => {
      n.removeAttribute('style');
      n.removeAttribute('fill');
      n.removeAttribute('stroke');
    });

    // Wrap glyphs so we can scale consistently
    let g = svg.querySelector('g[data-pc-glyph]');
    if (!g) {
      g = document.createElementNS('http://www.w3.org/2000/svg', 'g');
      g.setAttribute('data-pc-glyph', '1');
      while (svg.firstChild) g.appendChild(svg.firstChild);
      svg.appendChild(g);
    }

    svg.setAttribute('width', '100%');
    svg.setAttribute('height', '100%');
    svg.setAttribute('preserveAspectRatio', 'xMidYMid meet');

    el.innerHTML = '';
    el.appendChild(svg);

    // --- Normalize visual height ---
    requestAnimationFrame(() => {
      let bbox;
      try { bbox = g.getBBox(); } catch { return; }
      if (!bbox.height) return;

      const TARGET = 78; // visual target height (tune if needed)
      let scale = TARGET / bbox.height;

      // Clamp so skinny cursive letters don’t explode
      scale = Math.max(0.85, Math.min(1.25, scale));

      const vb = svg.viewBox.baseVal;
      const cx = bbox.x + bbox.width / 2;
      const cy = bbox.y + bbox.height / 2;

      const tx = vb.width / 2 - cx * scale;
      const ty = vb.height / 2 - cy * scale;

      g.setAttribute(
        'transform',
        `translate(${tx.toFixed(2)} ${ty.toFixed(2)}) scale(${scale.toFixed(4)})`
      );
    });

  } catch (err) {
    // Fallback: plain img
    el.innerHTML = `<img src="${item.src}" draggable="false">`;
  }
})();

// Desktop: drag-to-place (no tap-to-arm)
// Touch: keep tap-to-arm (and still supports touch-drag)
el.onpointerdown = (e) => {
  if (e.pointerType === 'mouse' && e.button !== 0) return;

  const startX = e.clientX;
  const startY = e.clientY;
