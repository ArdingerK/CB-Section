function nudgePaletteScroll(px = 90) {
  const pal = root.querySelector('.pc-sd__palette');
  if (!pal) {
    console.log('[DEBUG] Palette not found');
    return;
  }

  console.log('[DEBUG] Palette scroll check:', {
    scrollHeight: pal.scrollHeight,
    clientHeight: pal.clientHeight,
    scrollTop: pal.scrollTop,
    overflowY: getComputedStyle(pal).overflowY
  });

  // If there is nothing to scroll, bail
  if (pal.scrollHeight <= pal.clientHeight + 1) {
    console.log('[DEBUG] Nothing to scroll');
    return;
  }

  const next = Math.min(pal.scrollTop + px, pal.scrollHeight - pal.clientHeight);

  // Safari/iOS: smooth can be flaky; keep a safe fallback
  try {
    pal.scrollTo({ top: next, behavior: 'smooth' });
  } catch (e) {
    pal.scrollTop = next;
  }
}

