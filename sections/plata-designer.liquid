  function parseCSVLine(line) {
    const result = [];
    let cur = "";
    let inQuotes = false;
    for (let i = 0; i < line.length; i++) {
      let char = line[i];
      if (char === '"') {
        inQuotes = !inQuotes;
      } else if (char === ',' && !inQuotes) {
        result.push(cur.trim());
        cur = "";
      } else {
        cur += char;
      }
    }
    result.push(cur.trim());
    return result.map(v => v.replace(/^"|"$/g, '').trim());
  }
 function fitBoardToViewport() {
  const wrap = root.querySelector('.pc-sd__canvas-wrapper');
  const area = root.querySelector('.pc-sd__canvas-scroll-area');
  if (!wrap || !area) return;

  // Get board size from CSS variables (already set by updateBoard)
  const boardW = parseFloat(getComputedStyle(wrap).getPropertyValue('--boardWpx'));
  const boardH = parseFloat(getComputedStyle(wrap).getPropertyValue('--boardHpx'));
  if (!boardW || !boardH) return;

  const areaRect = area.getBoundingClientRect();
  const cs = window.getComputedStyle(area);
  const padX = (parseFloat(cs.paddingLeft) || 0) + (parseFloat(cs.paddingRight) || 0);
  const padY = (parseFloat(cs.paddingTop) || 0) + (parseFloat(cs.paddingBottom) || 0);

  let availW = Math.max(120, areaRect.width - padX);
  let availH = Math.max(180, areaRect.height - padY);

  const bar = root.querySelector('.pc-sd__bottombar');
  const barH = bar ? bar.getBoundingClientRect().height : 0;
  availH -= barH;

  const zoom = Math.min(availW / boardW, availH / boardH);
  const clamped = Math.max(0.25, Math.min(1, zoom));

  if (!userSetZoom) {
    setZoom(clamped);
  }
}

  async function loadLibrary() {
  try {
    console.log('[Stencil Designer] Fetching CSV:', CSV_URL);

    const resp = await fetch(CSV_URL, { cache: 'no-store' });
    console.log('[Stencil Designer] CSV status:', resp.status, resp.statusText);

    const text = await resp.text();

    // Common failure: Google returns an HTML page instead of CSV
    if (text.trim().startsWith('<!') || text.toLowerCase().includes('<html')) {
      console.error('[Stencil Designer] CSV returned HTML, not CSV. First 300 chars:\n', text.slice(0, 300));
      stencilGrid.innerHTML =
        "Error syncing library. (Google returned HTML instead of CSV — check Publish settings / URL.)";
      return;
    }

    const rows = text.split(/\r?\n/).filter(r => r.trim());
    if (rows.length < 2) {
      console.error('[Stencil Designer] CSV has no data rows. First 300 chars:\n', text.slice(0, 300));
      stencilGrid.innerHTML =
        "Error syncing library. (CSV appears empty or not published correctly.)";
      return;
    }

    const headerRow = parseCSVLine(rows[0]);
    const headers = headerRow.map(h => (h || '').toLowerCase());

    const idx = {
      name: headers.indexOf('stencil name'),
      url: headers.findIndex(h => h.includes('url') || h.includes('link') || h.includes('src')),
      w: headers.indexOf('width'),
      h: headers.indexOf('height'),
      pack: headers.indexOf('pack')
    };

    // Hard fail if we can't find URL column
    if (idx.url === -1) {
      console.error('[Stencil Designer] Could not find URL column. Headers were:', headerRow);
      stencilGrid.innerHTML =
        "Error syncing library. (Couldn't find a URL column in the CSV header.)";
      return;
    }

    const library = rows.slice(1).map((row, i) => {
      const cols = parseCSVLine(row);

      const src = (cols[idx.url] || '').trim();
      if (!src || !src.startsWith('http')) return null;

      return {
        name: (cols[idx.name] || 'Stencil').trim(),
        src,
        w: parseFloat(cols[idx.w]) || 4,
        h: parseFloat(cols[idx.h]) || 0,
        pack: (cols[idx.pack] || 'General').trim()
      };
    }).filter(Boolean);

    console.log('[Stencil Designer] Loaded stencils:', library.length);
    if (!library.length) {
      stencilGrid.innerHTML =
        "No valid stencils found. (Check that your URL column contains full https links.)";
      return;
    }

    renderLibrary(library);

  } catch (e) {
    console.error('[Stencil Designer] Library load error:', e);
    stencilGrid.innerHTML =
      "Error syncing library. (See console → [Stencil Designer] Library load error)";
  }
}
function renderLibrary(lib) {
