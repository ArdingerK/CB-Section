      header.indexOf('variant')    !== -1 ? header.indexOf('variant') :
      header.indexOf('variant id') !== -1 ? header.indexOf('variant id') :
      -1;

    const typeIdx = header.indexOf('type'); // can be -1 (optional)

    if (keyIdx === -1 || idIdx === -1) {
      console.warn('[Stencil Designer] Variants sheet missing headers Pack_Key / Variant_ID');
      return;
    }
  
    const packs = {};
