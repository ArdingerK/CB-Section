    rows.slice(1).forEach(line => {
      const cols = parseCSVLine(line);

      const rawKey = (cols[keyIdx] || '').trim();
      const rawId  = (cols[idIdx] || '').trim();
      const rawType = (typeIdx !== -1 ? (cols[typeIdx] || '') : '').toLowerCase().trim();

      if (!rawKey || !rawId) return;

      const k = normalizePackKey(slugifyPackKey(rawKey));
      if (k.includes('season')) console.log('[Variants row]', { rawKey, k, rawId, rawType });


      // Keep IDs as strings (safe), convert to Number only at cart add time
      if (rawType === 'board' || k.startsWith('board-')) boards[k] = rawId;
      else packs[k] = rawId;
    });

    VARIANTS_PACKS = packs;
