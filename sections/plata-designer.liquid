function isIncludedForBoard(pk, boardPrefix) {
  // Use the original pack label from the sheet for matching
  const label = (PACK_LABEL_BY_KEY[pk] || pk).toLowerCase();
  const bp = (boardPrefix || '').toLowerCase();

  // Included only if the pack label contains the board name
  // e.g. "Porch Capital Letter Stencils" includes "porch"
  return bp && label.includes(bp);
}

function isOptionalPackKey(pk, boardPrefix) {
  pk = (pk || '').toLowerCase().trim();

  // Exclude all board-specific packs from Optional:
  // framed-*, oval-*, wreath-*, porch-*  (including any "board-" keys)
  if (isBoardPrefixed(pk)) {
    // allow exceptions if you ever want to sell a board-prefixed optional pack
    return OPTIONAL_PACK_ALLOWLIST.has(pk);
  }

  // Otherwise optional = not included for the current board
  return !isIncludedForBoard(pk, boardPrefix);
}


