function updateHintVisibility() {
  const hint = root.querySelector('.pc-sd__hint');
  if (!hint) return;

  // Always use the actual DOM stage element (your .pc-sd__placed are appended here)
  const stageEl =
    (stage && stage.nodeType === 1) ? stage :
    root.querySelector('.pc-sd__stage') ||
    root.querySelector('.pc-sd__stage-inner') ||
    root;

  if (!stageEl || !stageEl.querySelector) return;

  const hasStencil = !!stageEl.querySelector('.pc-sd__placed');

  if (hasStencil) {
    // beats mobile CSS like display:block!important
    hint.style.setProperty('display', 'none', 'important');
  } else {
    // revert to CSS default when empty
    hint.style.removeProperty('display');
  }
}


// run once on init
updateHintVisibility();

// keep it in sync if anything adds/removes placed stencils
if (!root.__pc_sd_hint_observer) {
  root.__pc_sd_hint_observer = true;

  const stageEl =
    (stage && typeof stage.container === 'function') ? stage.container() :
    (stage && stage.nodeType === 1) ? stage :
    root.querySelector('.pc-sd__stage') ||
    root.querySelector('.pc-sd__canvas-wrap') ||
    root;

  if (stageEl && typeof MutationObserver !== 'undefined') {
    if (stage) {
  const obs = new MutationObserver(updateHintVisibility);
  obs.observe(stageEl, { childList: true, subtree: true });
}
  }
}

function setZoom(z, { fromUser = false } = {}) {
  if (fromUser) userSetZoom = true;

  const zoom = Math.max(0.25, Math.min(2.5, Number(z) || 1));
  root.style.setProperty('--zoom', String(zoom));

  const pct = Math.round(zoom * 100) + '%';
  if (zoomValueTop) zoomValueTop.textContent = pct;
  if (zoomValueMobile) zoomValueMobile.textContent = pct;

  if (zoomSliderTop && Number(zoomSliderTop.value) !== zoom) zoomSliderTop.value = String(zoom);
  if (zoomSliderMobile && Number(zoomSliderMobile.value) !== zoom) zoomSliderMobile.value = String(zoom);

  const wrap = root.querySelector('.pc-sd__canvas-wrapper');
  const canvasEl = root.querySelector('.pc-sd__canvas');
  
  // DEBUG — open browser console and check these values
  console.log('[setZoom]', {
    zoom,
    bW: canvasEl?.style.getPropertyValue('--boardWpx'),
    bH: canvasEl?.style.getPropertyValue('--boardHpx'),
    wrapFound: !!wrap,
    canvasFound: !!canvasEl
  });

  const scrollArea = root.querySelector('.pc-sd__canvas-scroll-area');
  const bar = root.querySelector('.pc-sd__bottombar');
  if (scrollArea && bar) {
    const barH = bar.getBoundingClientRect().height || 100;
    scrollArea.style.paddingBottom = (barH + 32) + 'px';
  }
}

