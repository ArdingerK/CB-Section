    // If you tapped a placed stencil, let its handler run (select/drag)
    if (e.target && e.target.closest && e.target.closest('.pc-sd__placed')) return;

    // If we're armed to place, place NOW at this board tap
    if (pendingPlaceItem) {
      createPlacedStencil(pendingPlaceItem, lastPlace.x, lastPlace.y, pendingPlacePackKey);

      requestAnimationFrame(() => nudgePaletteScroll(90));
      pendingPlaceItem = null;
