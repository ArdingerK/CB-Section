  const move = (m) => {
    const dx = m.clientX - startX;
    const dy = m.clientY - startY;

    // Mouse + touch: if they move enough → DRAG
    if (!dragged && (Math.abs(dx) > 6 || Math.abs(dy) > 6)) {
