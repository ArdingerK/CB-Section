function clamp(n, min, max) {
  return Math.max(min, Math.min(max, n));
}

function getPlacedMetrics(el) {
  const r = el.getBoundingClientRect();
  const sr = stage.getBoundingClientRect();

  const wPct = (r.width / sr.width) * 100;
  const hPct = (r.height / sr.height) * 100;

  const x = parseFloat(el.style.left); // center (%)
  const y = parseFloat(el.style.top);  // center (%)

  const left = x - (wPct / 2);
  const right = x + (wPct / 2);
  const top = y - (hPct / 2);
  const bottom = y + (hPct / 2);

  return { el, x, y, wPct, hPct, left, right, top, bottom };
}


function alignSelected(mode) {
  if (selectedEls.size < 2) return;

  const items = Array.from(selectedEls).map(getPlacedMetrics);
  if (mode === 'space') {
  // Decide axis by how the items are arranged (centers), not by size.
  const xs = items.map(it => it.x);
  const ys = items.map(it => it.y);

  const rangeX = Math.max(...xs) - Math.min(...xs);
  const rangeY = Math.max(...ys) - Math.min(...ys);

  // If they're mostly stacked (bigger Y spread), space vertically
  mode = (rangeY >= rangeX) ? 'space-v' : 'space-h';
}


  if (mode === 'align-vertical') {
    // Align all to same X (average X)
    const avgX = items.reduce((a, it) => a + it.x, 0) / items.length;
    items.forEach(it => it.el.style.left = clamp(avgX, 0, 100) + '%');
    return;
  }

  if (mode === 'align-bottom') {
    // Align bottoms to the lowest bottom edge
    const maxBottom = Math.max(...items.map(it => it.bottom));
    items.forEach(it => {
      const newY = maxBottom - (it.hPct / 2);
      it.el.style.top = clamp(newY, 0, 100) + '%';
    });
    return;
  }

  if (mode === 'space-v') {
    // Equal spacing vertically between top-most and bottom-most selection
    const sorted = items.slice().sort((a, b) => a.y - b.y);
    if (sorted.length < 3) return;

    const topEdge = Math.min(...sorted.map(it => it.top));
    const bottomEdge = Math.max(...sorted.map(it => it.bottom));
    const totalH = sorted.reduce((a, it) => a + it.hPct, 0);
    const availableGap = (bottomEdge - topEdge) - totalH;
    const gap = availableGap / (sorted.length - 1);

    let cursor = topEdge;
    sorted.forEach(it => {
      const centerY = cursor + (it.hPct / 2);
      it.el.style.top = clamp(centerY, 0, 100) + '%';
      cursor += it.hPct + gap;
    });
    return;
  }
if (mode === 'space-h') {
  // Equal spacing horizontally between left-most and right-most selection
  const sorted = items.slice().sort((a, b) => a.left - b.left);
  if (sorted.length < 3) return;

  const leftEdge  = Math.min(...sorted.map(it => it.left));
  const rightEdge = Math.max(...sorted.map(it => it.right));

  const totalW = sorted.reduce((sum, it) => sum + it.wPct, 0);
  const availableGap = (rightEdge - leftEdge) - totalW;
  const gap = availableGap / (sorted.length - 1);

  // Keep the group anchored to the same leftEdge
  let cursor = leftEdge;

  sorted.forEach(it => {
    const centerX = cursor + (it.wPct / 2);

    // Clamp as a CENTER, not as a left value
    const clampedCenterX = clamp(centerX, it.wPct / 2, 100 - it.wPct / 2);

    it.el.style.left = clampedCenterX + '%';
    cursor += it.wPct + gap;
  });

  return;
}
}

