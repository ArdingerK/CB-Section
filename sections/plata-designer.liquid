=================================== */

/* Modal root */
[data-pc-sd-modal]{
  position: fixed !important;
  inset: 0 !important;
  z-index: 999999 !important;
  display: none;               /* hidden by default */
}

/* When open */
[data-pc-sd-modal].is-open{
  display: block !important;
}


/* The “card” container:
   We don't care what class you used—this targets the first non-backdrop child. */
[data-pc-sd-modal] > :not(.pc-sd__modal-backdrop){
  position: absolute !important;
  left: 50% !important;
  top: 50% !important;
  transform: translate(-50%, -50%) !important;

  width: min(560px, calc(100% - 24px)) !important;
  max-height: calc(100vh - 24px) !important;
  overflow: auto !important;

  background: #fff !important;
  border-radius: 18px !important;
  padding: 16px !important;
  box-shadow: 0 18px 60px rgba(0,0,0,.35) !important;
}
[data-pc-sd-modal] .pc-sd__modal-card{
  position: absolute !important;
  left: 50% !important;
  top: 50% !important;
  transform: translate(-50%, -50%) !important;

  width: min(560px, calc(100% - 24px)) !important;
  max-height: calc(100vh - 24px) !important;
  overflow: auto !important;

  background: #fff !important;
  border-radius: 18px !important;
  padding: 16px !important;
  box-shadow: 0 18px 60px rgba(0,0,0,.35) !important;
}


/* Keep the preview image from becoming a giant black rectangle */
[data-pc-sd-modal] .pc-sd__modal-img{
  width: 100% !important;
  max-height: 180px !important;
